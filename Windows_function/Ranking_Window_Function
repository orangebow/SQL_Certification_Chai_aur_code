SELECT
    e.student_id,
    s.name, 
    s.branch,
    SUM(score) AS total_Score,
    ROW_NUMBER() OVER
    (
        PARTITION BY s.branch
        ORDER BY SUM(e.score) DESC
    ) AS row_num,
    RANK() OVER
    (
    PARTITION BY s.branch
    ORDER BY SUM(e.score) DESC
    ) AS rank_num
    From exam_scores as e
INNER JOIN students as s on s.student_id = e.student_id
GROUP BY e.student_id, s.name, s.branch;


--DENSE_RANK() to assign Rohan the third Rank.
SELECT
    e.student_id,
    s.name, 
    s.branch,
    SUM(score) AS total_Score,
    ROW_NUMBER() OVER
    (
        PARTITION BY s.branch
        ORDER BY SUM(e.score) DESC
    ) AS row_num,
    RANK() OVER
    (
    PARTITION BY s.branch
    ORDER BY SUM(e.score) DESC
    ) AS rank_num,
    DENSE_RANK() OVER
    (
    PARTITION BY s.branch
    ORDER BY SUM(e.score) DESC
    ) AS dense_rank_num
    From exam_scores as e
INNER JOIN students as s on s.student_id = e.student_id
GROUP BY e.student_id, s.name, s.branch;
